# ==============================
# Pharma Shopper — Environment
# ==============================
# Copy to .env and fill in production values

# --- Node ---
NODE_ENV=production

# --- PostgreSQL ---
POSTGRES_USER=pharma
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=pharma_shopper
DB_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Database URL (auto-composed in docker-compose, set manually for local dev) ---
DATABASE_URL=postgres://pharma:CHANGE_ME_strong_password@db:5432/pharma_shopper

# --- wa-gateway ---
WA_GATEWAY_KEY=CHANGE_ME_random_api_key
WA_GATEWAY_PORT=5001

# --- API ---
JWT_SECRET=CHANGE_ME_random_jwt_secret_min_32_chars
API_PORT=3000

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Web ---
VITE_API_URL=/api
WEB_PORT=8080
